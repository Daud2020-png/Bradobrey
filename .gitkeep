document.querySelectorAll('.faq-item').forEach((item) => {
  item.addEventListener('toggle', () => {
    if (!item.open) return;

    document.querySelectorAll('.faq-item').forEach((other) => {
      if (other !== item) {
        other.open = false;
      }
    });
  });
});

:root {
  --bg: #0a0a0d;
  --bg-soft: #121319;
  --surface: rgba(255, 255, 255, 0.04);
  --surface-strong: rgba(255, 255, 255, 0.08);
  --stroke: rgba(255, 255, 255, 0.1);
  --text: #f4f1ea;
  --muted: #b9b2a5;
  --gold: #d8a85d;
  --gold-soft: rgba(216, 168, 93, 0.18);
  --shadow: 0 24px 80px rgba(0, 0, 0, 0.4);
  --radius-xl: 32px;
  --radius-lg: 24px;
  --radius-md: 18px;
  --container: min(1180px, calc(100% - 32px));
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: 'Inter', system-ui, sans-serif;
  background:
    radial-gradient(circle at top, rgba(216, 168, 93, 0.14), transparent 34%),
    linear-gradient(180deg, #0b0b0f 0%, #09090b 100%);
  color: var(--text);
}

a {
  color: inherit;
  text-decoration: none;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

.container {
  width: var(--container);
  margin: 0 auto;
}

.page-shell {
  padding-bottom: 48px;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 18px 0;
  backdrop-filter: blur(16px);
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 14px;
}

.brand__logo {
  display: grid;
  place-items: center;
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: linear-gradient(135deg, #f1c27b, #8c5c22);
  color: #09090b;
  font-weight: 800;
}

.brand strong,
.hero h1,
.section-heading h2,
.contact-card h2,
.price-card__head strong,
.hero-card strong {
  letter-spacing: -0.03em;
}

.brand small {
  display: block;
  color: var(--muted);
  margin-top: 2px;
}

.nav {
  display: flex;
  gap: 24px;
  color: var(--muted);
}

.nav a:hover {
  color: var(--text);
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  min-height: 54px;
  padding: 0 24px;
  border-radius: 999px;
  border: 1px solid transparent;
  font-weight: 600;
  transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
}

.button:hover {
  transform: translateY(-1px);
}

.button--sm {
  min-height: 46px;
  padding: 0 18px;
}

.button--primary {
  background: linear-gradient(135deg, #f0c27b, #c58d41);
  color: #131313;
  box-shadow: 0 18px 36px rgba(197, 141, 65, 0.25);
}

.button--secondary,
.button--ghost {
  background: rgba(255, 255, 255, 0.02);
  border-color: var(--stroke);
  color: var(--text);
}

.hero {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
  gap: 28px;
  padding: 56px 0 32px;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--gold);
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
}

.hero h1 {
  max-width: 760px;
  margin: 18px 0 20px;
  font-size: clamp(44px, 7vw, 84px);
  line-height: 0.94;
}

.hero__lead,
.section-heading p,
.price-card p,
.team-card p,
.review-card p,
.faq-item p,
.contact-card p {
  color: var(--muted);
  line-height: 1.7;
}

.hero__lead {
  max-width: 660px;
  font-size: 18px;
}

.hero__cta {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 32px;
}

.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding: 0;
  margin: 28px 0 0;
  list-style: none;
}

.hero__meta li,
.trustbar div {
  padding: 12px 16px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  color: var(--muted);
}

.card-glass,
.feature-card,
.price-card,
.team-card,
.review-card,
.faq-item,
.contact-card,
.gallery-card {
  border: 1px solid var(--stroke);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
  box-shadow: var(--shadow);
}

.hero__panel {
  padding: 18px;
  border-radius: var(--radius-xl);
}

.hero-visual {
  position: relative;
  min-height: 520px;
  padding: 24px;
  border-radius: calc(var(--radius-xl) - 8px);
  background:
    linear-gradient(180deg, rgba(10, 10, 13, 0.2), rgba(10, 10, 13, 0.8)),
    radial-gradient(circle at 20% 10%, rgba(216, 168, 93, 0.36), transparent 26%),
    linear-gradient(135deg, #34312d 0%, #18191f 100%);
  overflow: hidden;
}

.hero-visual__portrait,
.team-card__photo,
.gallery-card {
  position: relative;
  overflow: hidden;
}

.hero-visual__portrait {
  position: absolute;
  inset: 78px 18px 18px;
  border-radius: 28px;
  background:
    linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.55)),
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.08), transparent 30%),
    linear-gradient(160deg, #725538 0%, #191919 55%, #0b0b0e 100%);
}

.hero-visual__portrait::before,
.team-card__photo::before,
.gallery-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(transparent, rgba(0, 0, 0, 0.44)),
    repeating-linear-gradient(
      110deg,
      rgba(255, 255, 255, 0.02) 0 16px,
      rgba(255, 255, 255, 0) 16px 34px
    );
}

.hero-visual__badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  padding: 10px 16px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.hero-visual__stats {
  position: absolute;
  left: 24px;
  right: 24px;
  bottom: 24px;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.hero-visual__stats div,
.hero-card {
  padding: 18px;
  border-radius: 22px;
  background: rgba(15, 15, 18, 0.62);
  border: 1px solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px);
}

.hero-visual__stats strong,
.price-card__head strong {
  display: block;
  font-size: 24px;
  margin-bottom: 6px;
}

.hero-visual__stats span {
  color: var(--muted);
}

.hero-card {
  margin-top: 16px;
}

.trustbar {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.section {
  padding: 112px 0 0;
}

.section--accent {
  padding: 112px 0 0;
}

.section-heading {
  max-width: 780px;
  margin-bottom: 36px;
}

.section-heading--compact {
  max-width: 720px;
}

.section-heading h2,
.contact-card h2 {
  margin: 16px 0;
  font-size: clamp(34px, 4vw, 56px);
  line-height: 1;
}

.benefits-grid,
.pricing-grid,
.team-grid,
.reviews-grid {
  display: grid;
  gap: 20px;
}

.benefits-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.feature-card,
.price-card,
.team-card,
.review-card,
.faq-item,
.contact-card {
  border-radius: var(--radius-lg);
}

.feature-card,
.price-card,
.review-card,
.contact-card {
  padding: 24px;
}

.feature-card__number {
  display: inline-flex;
  margin-bottom: 26px;
  color: var(--gold);
  font-weight: 700;
}

.services-layout {
  display: grid;
  gap: 30px;
}

.pricing-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.price-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 18px;
}

.price-card--featured {
  background: linear-gradient(180deg, rgba(216, 168, 93, 0.2), rgba(255, 255, 255, 0.05));
}

.team-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.team-card {
  padding: 18px;
}

.team-card__photo {
  min-height: 320px;
  margin-bottom: 18px;
  border-radius: 22px;
  background: linear-gradient(145deg, #735133, #191919 70%);
}

.team-card__photo--two {
  background: linear-gradient(145deg, #8b6b47, #16171c 70%);
}

.team-card__photo--three {
  background: linear-gradient(145deg, #5c4938, #111114 70%);
}

.gallery-grid {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr 1fr;
  gap: 18px;
}

.gallery-card {
  min-height: 240px;
  padding: 20px;
  border-radius: 28px;
  display: flex;
  align-items: flex-end;
  background:
    linear-gradient(transparent, rgba(0, 0, 0, 0.6)),
    linear-gradient(145deg, rgba(216, 168, 93, 0.32), rgba(17, 17, 20, 0.9));
}

.gallery-card--wide {
  grid-column: span 2;
  min-height: 290px;
}

.gallery-card--tall {
  grid-row: span 2;
  min-height: 498px;
}

.gallery-card span {
  position: relative;
  z-index: 1;
  font-size: 20px;
  font-weight: 600;
}

.reviews-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.review-card footer {
  margin-top: 20px;
  color: var(--gold);
  font-weight: 600;
}

.faq-list {
  display: grid;
  gap: 16px;
}

.faq-item {
  padding: 0;
  overflow: hidden;
}

.faq-item summary {
  list-style: none;
  cursor: pointer;
  padding: 22px 24px;
  font-weight: 600;
}

.faq-item summary::-webkit-details-marker {
  display: none;
}

.faq-item p {
  margin: 0;
  padding: 0 24px 24px;
}

.contact-card {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
  gap: 26px;
  align-items: start;
}

.contact-card__info ul {
  padding: 0;
  margin: 0;
  list-style: none;
  display: grid;
  gap: 14px;
}

.contact-card__info li {
  color: var(--muted);
}

.hero__cta--stacked {
  margin-top: 24px;
}

@media (max-width: 1080px) {
  .hero,
  .contact-card,
  .gallery-grid,
  .benefits-grid,
  .pricing-grid,
  .team-grid,
  .reviews-grid,
  .trustbar {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .gallery-card--wide,
  .gallery-card--tall {
    grid-column: auto;
    grid-row: auto;
    min-height: 260px;
  }
}

@media (max-width: 820px) {
  .topbar {
    position: static;
    flex-wrap: wrap;
  }

  .nav {
    order: 3;
    width: 100%;
    overflow-x: auto;
    padding-bottom: 6px;
  }

  .hero,
  .contact-card,
  .benefits-grid,
  .pricing-grid,
  .team-grid,
  .reviews-grid,
  .gallery-grid,
  .trustbar {
    grid-template-columns: 1fr;
  }

  .hero {
    padding-top: 26px;
  }

  .hero__panel {
    order: -1;
  }

  .hero-visual {
    min-height: 420px;
  }

  .hero-visual__portrait {
    inset: 78px 14px 14px;
  }

  .hero-visual__stats {
    left: 14px;
    right: 14px;
    bottom: 14px;
    grid-template-columns: 1fr;
  }

  .section,
  .section--accent {
    padding-top: 84px;
  }

  .button,
  .button--sm {
    width: 100%;
  }

  .hero__cta {
    flex-direction: column;
  }
}
